generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT
  CASH
  INVESTMENT
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  YEARLY
}

enum InsightType {
  warning
  tip
  prediction
  achievement
}

enum ChatRole {
  user
  assistant
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  password     String
  name         String?
  apiKey       String?      // Encrypted API key for AI (Gemini/OpenAI)
  visionApiKey String?      // Encrypted API key for Google Vision OCR
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  accounts     Account[]
  budgets      Budget[]
  goals        Goal[]
  insights     Insight[]
  chatMessages ChatMessage[]
}

model Account {
  id           String        @id @default(cuid())
  userId       String
  name         String
  type         AccountType
  balance      Float         @default(0)
  currency     String        @default("USD")
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
}

model Transaction {
  id           String          @id @default(cuid())
  accountId    String
  amount       Float
  type         TransactionType
  category     String
  description  String?
  date         DateTime        @default(now())
  isRecurring  Boolean         @default(false)
  attachmentUrl String?        // URL de imagen adjunta (factura/recibo)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  account      Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([date])
  @@index([category])
}

model Budget {
  id         String       @id @default(cuid())
  userId     String
  category   String
  limitAmount Float
  period     BudgetPeriod @default(MONTHLY)
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
}

model Goal {
  id           String    @id @default(cuid())
  userId       String
  name         String
  targetAmount Float
  currentAmount Float    @default(0)
  deadline     DateTime?
  description  String?
  isCompleted  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isCompleted])
}

model Insight {
  id        String      @id @default(cuid())
  userId    String
  type      InsightType
  title     String
  content   String
  category  String?
  isRead    Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      ChatRole
  content   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}
